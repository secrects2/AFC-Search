# AFC 價格監控 — 環境變數設定
# 複製此檔為 .env 並填入實際值

# SerpAPI (主要搜尋) — 免費 250次/月，不需信用卡
# 註冊：https://serpapi.com/signup
SERPAPI_API_KEY=YOUR_SERPAPI_KEY_HERE

# Brave Search API (備援搜尋) — 免費 ~1000次/月
# 註冊：https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=YOUR_BRAVE_KEY_HERE

# 搜尋預算控制
SEARCH_DAILY_BUDGET=20
SEARCH_MONTHLY_BUDGET=500
SEARCH_CACHE_HOURS=168

# 搜尋供應商優先順序
DEFAULT_SEARCH_PROVIDER=serpapi
FALLBACK_SEARCH_PROVIDER=brave
