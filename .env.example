# AFC 價格監控 — 環境變數設定
# 複製此檔為 .env 並填入實際值

# SerpAPI (主要搜尋) — 免費 250次/月，不需信用卡
# 註冊：https://serpapi.com/signup
SERPAPI_API_KEY=YOUR_SERPAPI_KEY_HERE

# Brave Search API (備援搜尋) — 免費 ~1000次/月
# 註冊：https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=YOUR_BRAVE_KEY_HERE

# 搜尋預算控制
SEARCH_DAILY_BUDGET=20
SEARCH_MONTHLY_BUDGET=500
SEARCH_CACHE_HOURS=168

# 搜尋供應商優先順序
DEFAULT_SEARCH_PROVIDER=serpapi
FALLBACK_SEARCH_PROVIDER=brave

# Shopee 價格取得設定
# Shopee 會阻擋 requests / Playwright，建議使用第三方 API
# 支援 Apify / Scrapeless / Bright Data / Oxylabs 等服務
SHOPEE_PROVIDER=third_party
SHOPEE_THIRD_PARTY_API_URL=
SHOPEE_THIRD_PARTY_API_KEY=
SHOPEE_TIMEOUT_SECONDS=60
SHOPEE_MAX_RETRIES=1

# Shopee browser profile 設定
# 首次使用請先執行: python tools/setup_shopee_profile.py
SHOPEE_PROFILE_DIR=data/browser_profiles/shopee
SHOPEE_HEADLESS=false

# ScraperAPI — 被 429/403 封鎖時自動備援（免費 5000 次/月）
# 註冊：https://www.scraperapi.com/signup
SCRAPERAPI_KEY=

# 自備代理 IP（可選）
# PROXY_URL=http://user:pass@host:port
